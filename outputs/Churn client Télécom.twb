      <aliases enabled='yes' />
      <column caption='Churn Label' datatype='string' name='[Calculation_1097587891576832]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Churn_num] = 1 THEN &quot;Churn&quot; ELSE &quot;Non-Churn&quot; END' />
      </column>
      <column caption='Taux de Churn (%)' datatype='real' name='[Calculation_1097587891953665]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Churn_num])*100' />
      </column>
      <column caption='Nouveau Client' datatype='string' name='[Calculation_1097587892330498]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure]&lt;= 6 THEN &quot;Nouveau(&lt;= 6 mois)&quot; ELSE &quot;Fidèle&quot; END' />
      </column>
      <column caption='Tranche Ancienneté' datatype='string' name='[Calculation_1097587892789252]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure]&lt;= 12 THEN &quot;0-1 an&quot;&#13;&#10;ELSEIF [tenure] &lt;= 24 THEN &quot;1-2 ans&quot;&#13;&#10;ELSEIF [tenure] &lt;= 48 THEN &quot;2-4 ans&quot;&#13;&#10;ELSE &quot;4-6 ans&quot;&#13;&#10;END' />
      </column>
      <column caption='Nombre de clients' datatype='integer' name='[Calculation_1097587965218830]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='A risque' datatype='boolean' name='[Calculation_1097587973312528]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[tenure] &lt;= [Parameters].[Paramètre 1]' />
      </column>
      <column caption='[Taux de Churn (%)]/100' datatype='real' name='[Calculation_1097587987922967]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1097587891953665]/100' />
      </column>
      <column caption='Churn num' datatype='integer' name='[Churn_num]' role='dimension' type='ordinal' />
      <column datatype='string' name='[Contract]' role='dimension' type='nominal' />
      <column caption='Device Protection' datatype='string' name='[DeviceProtection]' role='dimension' type='nominal' />
      <column caption='Internet Service' datatype='string' name='[InternetService]' role='dimension' type='nominal' />
      <column caption='Monthly Charges' datatype='real' name='[MonthlyCharges]' role='measure' type='quantitative' />
      <column caption='Multiple Lines' datatype='string' name='[MultipleLines]' role='dimension' type='nominal' />
      <column caption='Online Backup' datatype='string' name='[OnlineBackup]' role='dimension' type='nominal' />
